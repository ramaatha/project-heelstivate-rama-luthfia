<!DOCTYPE html>
<html lang="id">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Profile — Heelstivate</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/main.css">
</head>

<body>
  <%- include('../partials/navbar') %>

    <div style="background: var(--earth-sand); border-bottom: 1px solid var(--earth-border); padding: 28px 0;">
      <div class="container">
        <h1 class="section-title" style="margin-bottom:4px;">Profile Saya</h1>
        <p class="section-subtitle" style="margin-bottom:0;">Kelola informasi akun kamu</p>
      </div>
    </div>

    <div class="container py-5">
      <div class="row g-4">
        <div class="col-md-4">
          <div
            style="background:#fff; border-radius:16px; border:1px solid var(--earth-border); padding:32px; text-align:center;">
            <img
              src="<%= user.Profile && user.Profile.avatarUrl ? user.Profile.avatarUrl : 'https://placehold.co/120x120/D7B896/3E2723?text=' + user.username[0].toUpperCase() %>"
              style="width:100px; height:100px; border-radius:50%; object-fit:cover; border:3px solid var(--earth-accent); margin-bottom:16px;"
              alt="">
            <h5 style="font-weight:800; color:var(--earth-dark); margin-bottom:4px;">
              <%= user.username %>
            </h5>
            <p style="color:var(--earth-muted); font-size:0.9rem; margin-bottom:10px;">
              <%= user.email %>
            </p>
            <span
              style="background: var(--earth-primary); color:#fff; font-size:0.75rem; font-weight:700; padding:4px 14px; border-radius:20px; text-transform:uppercase; letter-spacing:0.5px;">
              <%= user.role %>
            </span>
            <div style="margin-top:16px; padding-top:16px; border-top:1px solid var(--earth-border);">
              <p style="font-size:0.8rem; color:var(--earth-muted); margin-bottom:2px;">🗓️ Bergabung <%=
                  timeAgo(user.createdAt) %>
              </p>
              <p style="font-size:0.75rem; color:var(--earth-light); margin-bottom:0;">
                <%= formatDate(user.createdAt) %>
              </p>
            </div>
            <% if (user.Profile && user.Profile.phoneNumber) { %>
              <p style="margin-top:12px; font-size:0.85rem; color:var(--earth-muted);">📞 <%= user.Profile.phoneNumber
                  %>
              </p>
              <% } %>
                <% if (user.Profile && user.Profile.address) { %>
                  <p style="font-size:0.85rem; color:var(--earth-muted);">📍 <%= user.Profile.address %>
                  </p>
                  <% } %>
          </div>
        </div>

        <div class="col-md-8">
          <div style="background:#fff; border-radius:16px; border:1px solid var(--earth-border); padding:32px;">
            <h5 style="font-weight:800; color:var(--earth-dark); margin-bottom:24px;">✏️ Edit Profile</h5>
            <form action="/profile/update" method="POST" class="form-earth">
              <div class="mb-3">
                <label>Alamat</label>
                <input type="text" name="address" class="form-control"
                  value="<%= user.Profile && user.Profile.address ? user.Profile.address : '' %>"
                  placeholder="Alamat lengkap kamu">
              </div>
              <div class="mb-3">
                <label>Nomor HP</label>
                <input type="text" name="phoneNumber" class="form-control"
                  value="<%= user.Profile && user.Profile.phoneNumber ? user.Profile.phoneNumber : '' %>"
                  placeholder="08xxxxxxxxxx">
              </div>
              <div class="mb-4">
                <label>URL Foto Profil</label>
                <input type="url" name="avatarUrl" class="form-control"
                  value="<%= user.Profile && user.Profile.avatarUrl ? user.Profile.avatarUrl : '' %>"
                  placeholder="https://...">
              </div>
              <button type="submit" class="btn-earth" style="border-radius:8px; padding:12px 28px;">Simpan
                Perubahan</button>
            </form>
          </div>
        </div>
      </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>

</html>