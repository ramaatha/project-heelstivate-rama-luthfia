<script>
  window.addEventListener('pageshow', function(event) {
    if (event.persisted) {
      window.location.reload();
    }
  });
</script>

<nav class="navbar-earth">
  <a href="/" class="navbar-brand-text">Heel<span>stivate</span></a>
  <ul class="nav-links">
    <li><a href="/products">Semua Produk</a></li>
    <% if (session && session.userId) { %>
    <% if (session.role === 'seller') { %>
    <li><a href="/products/add">+ Jual</a></li>
    <li><a href="/dashboard">Dashboard</a></li>
    <% } else { %>
    <li><a href="/cart">🛒 Cart</a></li>
    <% } %>
    <li><a href="/profile"><%= session.username %></a></li>
    <li><a href="/logout" class="btn-nav">Keluar</a></li>
    <% } else { %>
    <li><a href="#" onclick="alert('Silakan login terlebih dahulu untuk mengakses keranjang belanja.'); return false;">🛒 Keranjang</a></li>
    <li><a href="/login">Masuk</a></li>
    <li><a href="/register" class="btn-nav">Daftar</a></li>
    <% } %>
  </ul>
</nav>
