<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= product.name %> — Heelstivate</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/main.css">
</head>
<body>
  <%- include('../partials/navbar') %>

  <div class="container py-5">
    <nav style="font-size:0.85rem; color:var(--earth-muted); margin-bottom:24px;">
      <a href="/" style="color:var(--earth-muted);">Home</a>
      <span class="mx-2">/</span>
      <a href="/products" style="color:var(--earth-muted);">Produk</a>
      <span class="mx-2">/</span>
      <span style="color:var(--earth-dark); font-weight:600;"><%= product.name %></span>
    </nav>

    <div class="row g-4">
      <div class="col-md-6">
        <div style="border-radius:16px; overflow:hidden; border:1px solid var(--earth-border);">
          <img src="<%= product.imgUrl || 'https://placehold.co/600x500/D7B896/3E2723?text=No+Image' %>"
            style="width:100%; height:460px; object-fit:cover; display:block;" alt="<%= product.name %>">
        </div>
      </div>

      <div class="col-md-6">
        <div class="detail-sidebar">
          <div class="d-flex gap-2 flex-wrap mb-3">
            <% if (product.Category) { %>
              <span class="badge-category"><%= product.Category.name %></span>
            <% } %>
            <% if (product.isBestSeller()) { %>
              <span class="badge-terlaris">🔥 Terlaris</span>
            <% } %>
          </div>

          <h2 style="font-size:1.6rem; font-weight:800; color:var(--earth-text); margin-bottom:8px;"><%= product.name %></h2>
          <div style="font-size:1.6rem; font-weight:900; color:var(--earth-primary); margin-bottom:16px;"><%= formatRupiah(product.price) %></div>

          <p style="color:var(--earth-muted); line-height:1.7; margin-bottom:20px;"><%= product.description %></p>

          <div style="background:var(--earth-sand); border-radius:10px; padding:16px; margin-bottom:20px; border:1px solid var(--earth-border);">
            <div class="row g-2 text-center">
              <div class="col-4">
                <div style="font-size:0.75rem; color:var(--earth-muted); margin-bottom:4px; text-transform:uppercase; font-weight:700;">Ukuran</div>
                <div class="size-badge mx-auto"><%= product.size %></div>
              </div>
              <div class="col-4">
                <div style="font-size:0.75rem; color:var(--earth-muted); margin-bottom:4px; text-transform:uppercase; font-weight:700;">Stok</div>
                <div style="font-weight:800; font-size:1.1rem; color:var(--earth-dark);"><%= product.stock %></div>
              </div>
              <div class="col-4">
                <div style="font-size:0.75rem; color:var(--earth-muted); margin-bottom:4px; text-transform:uppercase; font-weight:700;">Terjual</div>
                <div style="font-weight:800; font-size:1.1rem; color:var(--earth-primary);"><%= product.sold %></div>
              </div>
            </div>
          </div>

          <% if (product.User) { %>
            <p style="font-size:0.85rem; color:var(--earth-muted); margin-bottom:8px;">
              🏪 Dijual oleh <strong style="color:var(--earth-dark);"><%= product.User.username %></strong>
            </p>
          <% } %>
          <p style="font-size:0.82rem; color:var(--earth-muted); margin-bottom:20px;">
            🕐 Ditambahkan <%= timeAgo(product.createdAt) %> · <%= formatDate(product.createdAt) %>
          </p>

          <% if (session && session.role === 'buyer') { %>
            <% if (product.stock > 0) { %>
              <form action="/cart/<%= product.id %>" method="POST">
                <div class="d-flex gap-2 mb-3">
                  <div class="form-earth" style="flex:0 0 90px;">
                    <input type="number" name="quantity" class="form-control" value="1" min="1" max="<%= product.stock %>" style="text-align:center; font-weight:700;">
                  </div>
                  <button type="submit" class="btn-earth flex-grow-1" style="border-radius:8px;">🛒 Masukkan Keranjang</button>
                </div>
              </form>
            <% } else { %>
              <button class="btn w-100 mb-3" disabled style="background:#e8e0d8; color:var(--earth-muted); border-radius:8px; padding:12px; font-weight:600;">Stok Habis</button>
            <% } %>
          <% } %>

          <% if (session && session.role === 'seller' && session.userId == product.userId) { %>
            <div class="d-flex gap-2 mb-3">
              <a href="/products/<%= product.id %>/edit" class="btn-earth-outline flex-grow-1" style="display:block; text-align:center; padding:10px; border-radius:8px;">✏️ Edit</a>
              <form action="/products/<%= product.id %>/delete" method="POST" style="flex-grow:1;">
                <button type="submit" onclick="return confirm('Yakin hapus produk ini?')"
                  style="width:100%; background:#c62828; color:#fff; border:none; padding:10px; border-radius:8px; font-weight:600; cursor:pointer;">🗑️ Hapus</button>
              </form>
            </div>
          <% } %>

          <a href="/products" style="font-size:0.85rem; color:var(--earth-muted);">← Kembali ke Koleksi</a>
        </div>

        <div class="qr-box mt-3">
          <img src="<%= qrCode %>" alt="QR Code Produk" style="width:120px; height:120px;">
          <p>Scan QR untuk share produk ini</p>
        </div>
      </div>
    </div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
