<!DOCTYPE html>
<html lang="id">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Daftar — Heelstivate</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/main.css">
</head>

<body style="background: linear-gradient(135deg, var(--earth-dark) 0%, var(--earth-primary) 100%); min-height:100vh; display:flex; align-items:center; justify-content:center; padding:20px;">

  <div class="auth-card">
    <div class="text-center mb-4">
      <a href="/" class="auth-logo d-block" style="text-decoration:none;">Heel<span>stivate</span></a>
      <p style="color:var(--earth-muted); font-size:0.9rem; margin-top:6px;">Buat akun baru</p>
    </div>

    <% if (errors && errors.length > 0) { %>
    <div style="margin-bottom:16px;">
      <% errors.forEach(function(msg) { %>
      <p style="color:#c62828; font-size:0.9rem; margin-bottom:6px;">⚠️ <%= msg %></p>
      <% }) %>
    </div>
    <% } %>

    <form action="/register" method="POST" class="form-earth" novalidate>
      <div class="mb-3">
        <label>Username</label>
        <input type="text" name="username" class="form-control" placeholder="Username kamu" value="<%= old.username || '' %>">
      </div>
      <div class="mb-3">
        <label>Email</label>
        <input type="email" name="email" class="form-control" placeholder="contoh@email.com" value="<%= old.email || '' %>">
      </div>
      <div class="mb-3">
        <label>Password</label>
        <input type="password" name="password" class="form-control" placeholder="Min. 8 karakter">
      </div>
      <div class="mb-4">
        <label>Daftar sebagai</label>
        <select name="role" class="form-select">
          <option value="">-- Pilih role --</option>
          <option value="buyer" <%= old.role === 'buyer' ? 'selected' : '' %>>Buyer</option>
          <option value="seller" <%= old.role === 'seller' ? 'selected' : '' %>>Seller</option>
        </select>
      </div>
      <button type="submit" class="btn-earth w-100" style="border-radius:8px; padding:12px;">Buat Akun</button>
    </form>

    <p class="text-center mt-4" style="font-size:0.9rem; color:var(--earth-muted);">
      Sudah punya akun? <a href="/login" style="color:var(--earth-primary); font-weight:700;">Masuk di sini</a>
    </p>
  </div>

</body>

</html>